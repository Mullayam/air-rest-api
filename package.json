{
  "name": "air-rest-api",
  "version": "1.0.0",
  "description": "",
  "main": "start.ts",
  
   
  "scripts": {
    "build": "tsc",
    "dev": "nodemon start.ts",
    "start": "nodemon"
  },
  "keywords": [
    "express",
    "lightapi",
    "rest-api"
  ],
  "author": "ENJOYS",
  "license": "MIT",
  "_moduleAliases": {   
    "App/*": "./src/app/*",
    "Logs/*": "./src/app/logs/*",    
    "Controllers": "./src/app/controllers/index.ts",
    "Config/*": "./src/app/config/*",
    "Factory/*":"./src/factory/*",    
    "Types/*": "./src/types/*",
    "Storage/*": "./src/storage/*",
    "Routes/*": "./src/routes/*",
    "ApiRoutes": "./src/routes/api/ApiRoutes.ts",
    "AppModules/*": "./src/components/*",
    "Helpers/*": "./src/components/helpers/*",
    "Services/*": "./src/components/services/*"   
  },
  "_moduleDirectories": [
    "src"
  ],
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.1",
    "mysql2": "^3.6.0",
    "typeorm": "^0.3.17",
    "typescript": "^5.1.6",
    "module-alias": "^2.2.3",
    "validator": "^13.11.0"
    
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.2",
    "@types/express": "^4.17.17",
    "@types/module-alias": "^2.0.1",
    "@types/node": "^20.4.8",
    "chalk": "^5.3.0",
   
    "winston": "^3.10.0"
  }
}
